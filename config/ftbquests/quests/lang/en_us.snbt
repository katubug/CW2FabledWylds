	quest.4D65AA1353AA0E1D.quest_desc: [
		"The &bCrafting Bowl&r is a ubiquitous kitchen tool used to &amix together ingredients&r for things such as &bDough&r, &bSweet Dough&r, and &bCake Dough&r! You can also use it to &6make &bButter&r."
		""
		"You can &6hover over it in your inventory and press U&r to &aview its recipes&r."
		""
		"To actually &ause it&r, first &6place it down&r and then &6click it with the ingredients&r. Once it's got everything, then you can &6hold right click to stir&r until it's fully blended, then &6right click again&r to claim the completed recipe!"
	]
	quest.4D65AA1353AA0E1D.quest_subtitle: "you feel something stirring"
