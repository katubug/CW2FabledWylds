	quest.706D91D3C11487E5.quest_desc: [
		"Prove to the world that you can handle the heat in the kitchen by &6cooking one of every dish&r from the base &lFarmer's Delight&r mod. Earn your cap and have lesser cooks telling you, \"Yes Chef!\""
		""
		"View your progress by pressing &6ctrl+L&r!"
		""
		"Items needed to complete quest: "
		""
		"- Vegetable Soup"
		"- Shepherds Pie"
		"- Honey Glazed Ham"
		"- Ratatouille"
		"- Grilled Salmon"
		"- Mixed Salad"
		"- Roasted Mutton Chops"
		"- Squid Ink Pasta"
		"- Pasta with Meatballs"
		"- Steak and Potatoes"
		"- Chicken Soup"
		"- Pumpkin Soup"
		"- Mushroom Rice"
		"- Vegetable Noodles"
		"- Fish Stew"
		"- Stuffed Pumpkin"
		"- Beef Stew"
		"- Roast Chicken"
		"- Bacon and Eggs"
		"- Pasta with Mutton Chops"
		"- Fried Rice"
	]
