	quest.2092DA35710A97AA.quest_subtitle: "{components:{\"minecraft:enchantments\":{levels:{\"betternether:obsidian_breaker\":3,\"betternether:ruby_fire\":1,\"minecraft:mending\":1}}},count:1,id:\"betternether:flaming_ruby_pickaxe\"}"
	quest.2093240CD42882CF.quest_desc: [
		"Scattered around the world, you can find &bWild Crops&r growing. Find all of them to build your &alovely witchy garden&r!"
		""
		"Did you know that even vegetables can be used in household magic? For example, corn hung over a mirror will bring good luck to your household. Or, you can take a small white onion and stick it full of black-headed pins, and when placed in the window, this will protect against negativity."
		""
		"Click to the next page for information on &awhich items can be found where&r!"
		""
		"{@pagebreak}"
		"&bWild Tomatoes&r can be found in &chot, dry biomes&r."
		""
		"&bWild Rice&r can be found growing in &bwater&r in &cwet biomes&r."
		""
		"&bWild Cabbages&r can be found in &cbeach biomes&r."
		""
		"&bWild Coffee&r can be found in &cthe Nether&r!"
		""
		"&bOnions&r, &bCarrots&r, and &bPotatoes&r can be found in most any biome!"
		""
		"&bBarley&r can be found in &cPlains&r and &cSavannahs&r."
		""
		"&bEmmer&r is located in &cForests&r."
		""
		"&bOats&r are found in &cTaiga&r biomes."
		""
		"&bCorn&r can be found in &cSavannah&r and &cBadlands&r biomes."
		""
		"&bNettles&r and &bRibwort&r spawn in &cSwamps&r and &cMangrove Swamps&r."
		""
		"&bBlueberries&r, &bRaspberries&r, and &bPeanuts&r come from &ctemperate overworld biomes&r, so think plains, forests, meadows, birch forests."
		""
		"&bWild Green Grapes&r come from &chot biomes&r: savannas, deserts, badlands, jungles."
		""
		"&bWild Red Grapes&r are from &ccold biomes&r: taiga, snowy plains, etc."
		""
		"&bWild Cotton&r can be found in &csavanna&r, &cbadlands&r, etc."
	]
	quest.2093240CD42882CF.title: "Forage Wild Crops"
