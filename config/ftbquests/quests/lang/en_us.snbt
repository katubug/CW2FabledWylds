	quest.54AAA9079FF8E65B.quest_desc: [
		"The Green &cSempiternal Sanctum&r grants a chance at the &bEssence of Life&r."
		""
		"Holding this item in offhand will &agrow crops and saplings nearby&r, revive &bDead Bushes&r into a random sapling, &aheal mobs tamed by you&r, and &aheal other mobs or players&r on the same team as you! Also, will cure &bPoison and &bWither effects&r."
		""
		"It has &a1000 uses before it is depleted&r and needs 10 minutes to recharge by being in the inventory of a player that had consumed &bEssence of the Bees&r in the past."
	]
	quest.54AAA9079FF8E65B.title: "Sempiternal Sanctum: Green"
	quest.54AAAA821BD1772F.quest_subtitle: "{components:{\"ae2:facade_item\":\"betterend:sandy_jadestone_polished\"},count:1,id:\"ae2:facade\"}"
	quest.54B176A22CBFD31F.quest_desc: [
		"Scattered throughout your world are various &bSky Structures&r, of which &bCloud Islands&r are a part!"
		""
		"You may need a &bBroom&r to reach them. Or a whole lot of &bBlocks&r."
	]
