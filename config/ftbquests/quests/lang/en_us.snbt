	quest.64E8A8E1C9A939C9.quest_desc: [
		"The central crafting station for the savvy witch - the most mechanically complex cauldron in our catalogue!"
		""
		"How it works:"
		""
		"- Has a full GUI: 8 ingredient slots, 1 fluid slot, 1 sigil slot"
		"- Fill with a fluid first (water, tallow, blood, lava, or potion fluid)"
		"- Add up to 8 ingredients"
		"- Some recipes &arequire heat&r below (lava, magma block, campfire, etc.)"
		"- Some recipes &arequire a specific moon phase&r (check in-game Book of Shadows)"
		"- The &bCandle Dipper&r attaches on top to dip string/candles into the cauldron's fluid"
		""
		"&lWhat it makes&r: Most Hexerei crafting outputs - Blood Sigil, Flying Ointment-adjacent items, brewed items, magical essences, and more!"
		""
		"&bBlood&r is also produced here: place a &bBlood Sigil&r in the sigil slot and jump in 3 times to fill the cauldron with delici - uh, I mean, regular human blood."
	]
	quest.64E8A8E1C9A939C9.title: "The Mixing Cauldron"
	quest.64EA5895BDE09EB5.quest_subtitle: "{components:{\"starcatcher:message\":{dimension:\"minecraft:overworld\",locked:1b,sender:[I;-953618982,356402112,-1130421744,-1565335126],sender_display_name:\"<sclegendary>-dev (wd)</sclegendary>\",text:[\"\",\"\",\"This is a cheated message from creative.\",\"\",\"Usually players would write their own\",\"message and send it to the ocean for\",\"others to fish later.\",\"(5% chance if there is any available)\",\"\",\"<scgolden>Also did you know it supports markdown?</scgolden>\",\"learn more about it in the LibTooltips wiki\"]}},count:1,id:\"starcatcher:bottled_letter\"}"
