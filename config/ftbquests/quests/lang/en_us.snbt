	quest.3556685D896ADA7C.quest_desc: [
		"&eGoats&r are ornery things. If you should happen across one, &abeware of their headbutts&r! "
		"However, if you can get it to &acharge into a hard block&r such as &bStone&r, it will drop a &bHorn&r."
	]
	quest.3556685D896ADA7C.title: "Meet the Goat"
	quest.3556A85E67AEB2A7.quest_subtitle: "{count:1,id:\"minecraft:black_stained_glass\"}"
	quest.3558EAA43C9F9F2D.quest_desc: [
		"&bAnt Mounts&r (no, not mounds, mounts!) are a new dungeon structure found in &cAnt Gardens&r."
		""
		"They have 4 possible variations and are &aFULL of Ants and Ant Mounds&r."
		""
		"To navigate through one, &6brush the Ant Mounds&r and &6dig the &bPacked Mud&r to get to other chambers. &dDon't hit the ants or break &bMounds&r or &bAnthills&r! This will cause the &aAnts to anger and attack you&r."
		""
		"Inside these mounts you can find two unique &bSherds&r and even a new &bMusic Disc&r!"
	]
	quest.3558EAA43C9F9F2D.quest_subtitle: "no you cannot mount the ants"
	quest.3558EAA43C9F9F2D.title: "Discover the Ant Mount"
