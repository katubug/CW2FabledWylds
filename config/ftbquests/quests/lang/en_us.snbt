	quest.24993E3FC9E3BA2D.quest_desc: [
		"You want to make &bArt&r? You'll need &bColor&r. Whether you're &apainting&r, &asketching&r, or &adeveloping color photos&r, you'll need lots of &bDye&r."
		""
		"Collecting one of each kind will reward you with more!"
		""
		"[ \"You can also purchase more dye from our \", { \"text\": \"Mail Order Catalogue\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"4971EB753FE0E6CC\" } }]"
	]
	quest.24993E3FC9E3BA2D.quest_subtitle: "omg i'm literally dyeing rn"
	quest.24993E3FC9E3BA2D.title: "Obtain One of Each Dye"
	quest.2499CAE3934539A8.quest_desc: [
		"You did it! You beat the game. Congrats, you can all go home now."
		"...."
		"...."
		"...oh, you're staying. Well, hooray! Maybe check out the other quests, since you're here!"
	]
