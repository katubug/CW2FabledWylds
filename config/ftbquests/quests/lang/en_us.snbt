	quest.1547891EBE53934F.quest_desc: [
		"The &bWrench&r is an item which can &arotate blocks&r. Just &6right click the block&r with the &bWrench&r, and it will adjust the position based on where you click it."
		""
		"Does not work on objects which have the same texture on all sides (such as planks)."
	]
