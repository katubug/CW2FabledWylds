	quest.057C8372ED1CBDC0.quest_desc: [
		"Okay so YES, &otechnically&r these aren't all vegetables. &bTomatoes&r are a fruit, &bPotatoes&r are a tuber, and no one really knows what &bCabbage&r is or why it exists. Stop being so pedantic and get your @$#%# together."
		""
		"(&8@$#%# means vegetables. get them together into a crate&r)"
	]
	quest.057C8372ED1CBDC0.title: "Compact Your Crops: Veggies"
