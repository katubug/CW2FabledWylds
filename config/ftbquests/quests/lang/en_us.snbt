	quest.69E3182321452B88.quest_desc: [
		"The &bEasel&r allows you to &acustomize which painting you want to hang&r!"
		""
		"Simply &6insert the painting and click the rectangles&r to select the painting size, then &6select the image&r with the arrow buttons, and withdraw your painting!"
		""
		"When selecting the size: The rectangles are not a toggle, so left clicking more than once will not unselect the one you've chosen. You need to click the one above or to the left to select a smaller size."
		""
		"{image:enchanted_wilds:textures/questimages/easel_interface.png width:250 height:180 align:center}"
	]
