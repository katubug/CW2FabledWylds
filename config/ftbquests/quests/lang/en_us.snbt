	quest.374F93068ED863F7.quest_desc: [
		"Pottery &bSherds&r are relics of times long past, and also a handy crafting ingredient!"
		""
		"You can &aduplicate them&r by &6surrounding them with &bBricks&r."
		""
		"You can &agild &8(some of)&r&a them&r by &6crafting them with &bGold Nuggets&r. Gilded sherds can &aalso be duplicated&r."
		""
		"Finally, you can reconstruct them into &bPots&r by &6combining any 4 &bSherds or Bricks&r like so:"
		""
		"{image:enchanted_wilds:textures/questimages/potterysherd.png width:205 height:200 align:1}"
	]
	quest.374F93068ED863F7.title: "Obtain A Sherd"
