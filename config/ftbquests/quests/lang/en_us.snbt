	quest.393CF105AAFA6CF0.quest_desc: [
		"Don't you get tired of having to &aopen your backpack to get things&r? Isn't it annoying to have to &aput food in your mouth&r every time you're hungry? Who has time to &aswitch between their axe and pickaxe&r when harvesting materials?"
		""
		"Get yourself a backpack that does it all with these upgrades. No more wasted time &agrabbing the next stack of blocks&r or even &aopening your backpack to refill it.&r You're busy and have more important matters to attend to."
		""
		"To get the most of these upgrades, we suggest &6checking out the settings tab&r for each one. "
		""
		"Your settings will be saved for each upgrade &aeven if you remove it.&r"
	]
	quest.393CF105AAFA6CF0.quest_subtitle: "\"i don't like to do anything\" - Docm77"
	quest.393CF105AAFA6CF0.title: "Shortcut Upgrades"
