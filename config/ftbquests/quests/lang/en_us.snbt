	quest.0DDBFB778B945B97.quest_desc: [
		"The &bEnder Drawer&r allows you to access the same inventory from &amultiple locations&r. Very useful if you need to access the same blocks frequently in different workshops!"
		""
		"To link them, you'll need a &bLinking Tool&r. &6Left click the main &bEnder Drawer&r, and it should say \"stored frequency in the tool&r. Then, &6shift right click&r the second inventory to have it mimic the first!"
	]
	quest.0DDBFB778B945B97.quest_subtitle: "the same inventory in two places"
