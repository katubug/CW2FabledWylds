	quest.511581BF899A9D1D.quest_desc: [
		"A &bDrawer&r is a storage item that can store &large amounts&r of single items, &astacking beyond the normal limit&r. A 1x1 drawer can hold a single item type. A 2x2 drawer can hold four item types, but less of each."
		""
		"The &bDrawers&r are also handy in that they &adisplay their contents&r, making them an excellent choice for items you need frequent access to."
	]
	quest.511581BF899A9D1D.quest_subtitle: "drawers and artists are distinct things"
	quest.511581BF899A9D1D.title: "Functional Storage through Drawers"
