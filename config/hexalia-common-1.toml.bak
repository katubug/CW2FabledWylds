#Settings for functional blocks and world structures
[functional_blocks]
	#Radius in blocks around the Censer where its effect is applied
	# Default: 16
	# Range: 1 ~ 64
	censerEffectRadius = 16
	#Burn duration in ticks of the Censer effect. 20 ticks = 1 second
	# Default: 7200
	# Range: 20 ~ 24000
	censerEffectDuration = 7200
	#Radius in blocks the Dreamcatcher detects and affects phantoms
	# Default: 16
	# Range: 1 ~ 64
	radius = 16
	#Duration in ticks phantoms are set on fire by the Dreamcatcher
	# Default: 100
	# Range: 0 ~ 600
	phantomIgniteDuration = 100
	#Overcook duration in ticks of the Small Cauldron. 20 ticks = 1 second
	# Default: 4800
	# Range: 20 ~ 24000
	brewingDuration = 4800
	#Time in ticks required for Egg Clusters to hatch. Default: 9600 ticks (8 minutes)
	# Default: 9600
	# Range: 20 ~ 24000
	eggClusterHatchDuration = 9600

#Enchanted plant behavior and effect settings
[plants]
	#Duration in ticks the Nautilite remains active. Default: 2400 ticks (2 minutes)
	# Default: 2400
	# Range: 100 ~ 24000
	nautiliteDuration = 2400
	#Radius in blocks affected by the Nautilite
	# Default: 16
	# Range: 1 ~ 64
	nautiliteEffectRadius = 16
	#Duration in ticks the Windsong barrier remains active. Default: 600 ticks (30 seconds)
	# Default: 600
	# Range: 100 ~ 24000
	windsongDuration = 600
	#Radius in blocks of the Windsong projectile-deflecting barrier
	# Default: 6
	# Range: 1 ~ 32
	windsongEffectRadius = 6
	#Duration in ticks the Astrylis remains active. Default: 1200 ticks (1 minute)
	# Default: 1200
	# Range: 100 ~ 24000
	astrylisDuration = 1200
	#Interval in ticks between Astrylis bonemeal pulses. Default: 240 ticks (12 seconds)
	# Default: 240
	# Range: 20 ~ 1200
	astrylisBonemealInterval = 240
	#Radius in blocks around the Morphora where mutation occurs
	# Default: 6
	# Range: 1 ~ 32
	morphoraEffectRadius = 6
	#Radius in blocks affected by the Grimshade aura
	# Default: 16
	# Range: 1 ~ 64
	grimshadeEffectRadius = 16
	#Duration in ticks the Grimshade remains active. Default: 2400 ticks (2 minutes)
	# Default: 2400
	# Range: 100 ~ 24000
	grimshadeDuration = 2400
	#Duration in ticks the Lourdes Enchanted Flower remains active. Default: 600 ticks (30 seconds)
	# Default: 600
	# Range: 100 ~ 24000
	lourdesDuration = 600
	#Radius in blocks affected by the Lourdes healing and cleansing aura
	# Default: 8.0
	# Range: 1.0 ~ 64.0
	lourdesEffectRadius = 8.0

#Miscellaneous gameplay and system settings
[others]
	#If true, block mutations will spawn item entities instead of directly placing blocks
	mutationSpawnsItemEntity = true
	#Radius in blocks affected by the Mandrake scream. Default: 5.0
	# Default: 5.0
	# Range: 1.0 ~ 32.0
	mandrakeScreamRadius = 5.0
	#Stun duration in seconds applied by the Mandrake scream. Default: 6 seconds
	# Default: 6
	# Range: 1 ~ 60
	mandrakeStunDuration = 6
	#Duration in seconds of the poisonous cloud created by the Foul Sac. Default: 8 seconds
	# Default: 8
	# Range: 1 ~ 60
	foulSacDuration = 8
	#Duration in seconds of the searing cloud created by the Searing Sac. Default: 8 seconds
	# Default: 8
	# Range: 1 ~ 60
	frostSacDuration = 8
	#Duration in seconds of the cleansing cloud created by the Purifying Sac. Default: 8 seconds
	# Default: 8
	# Range: 1 ~ 60
	purifyingSacDuration = 8
	#Radius in blocks for the Siphon effect. Default: 5.0
	# Default: 5.0
	# Range: 0.5 ~ 64.0
	siphonRadius = 5.0
	#Damage applied by the Bleeding effect per tick (in half-hearts). Default: 0.5
	# Default: 0.5
	# Range: 0.0 ~ 10.0
	bleedingDamage = 0.5
	#Radius in blocks the tamed Cacofey scans for mature crops when anchored. Default: 16
	# Default: 16
	# Range: 4 ~ 64
	cacofeyHarvestRadius = 16
